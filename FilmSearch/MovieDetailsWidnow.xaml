<Window x:Class="FilmSearch.MovieDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movie Details" Height="450" Width="600">
    <Grid>
        <!-- Tutaj możesz dodać interfejs użytkownika dla szczegółów filmu -->
        <StackPanel Margin="20">
            <TextBlock Text="{Binding SelectedMovie.Title}" FontWeight="Bold" FontSize="24" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding SelectedMovie.Description}" TextWrapping="Wrap" Margin="0,0,0,10"/>
            <TextBlock Text="Rating: " FontWeight="Bold"/>
            <TextBlock Text="{Binding SelectedMovie.Rating}" Margin="0,0,0,10"/>
        </StackPanel>
    </Grid>
</Window>
