<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="MovieSearchWPF.MainWindow"
        mc:Ignorable="d"
        Height="600" 
        Width="920" 
        WindowStyle="None" 
        ResizeMode="NoResize" 
        Background="Transparent" 
        AllowsTransparency="True">

    <Border Background="#3a3b3a" CornerRadius="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="75"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock Text="MasneFilmy" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Left" 
                    Foreground="White"
                    FontSize="22"
                    Margin="20,0,0,0"/>

            <StackPanel Grid.Row="1">

                <RadioButton Content="Movies"
                        Height="50"
                        Foreground="White"
                        FontSize="14"
                        Style="{StaticResource MenuButtonTheme}"/>

                <RadioButton Content="TV Shows"
                        Height="50"
                        Foreground="White"
                        FontSize="14"
                        Style="{StaticResource MenuButtonTheme}"/>

                <RadioButton Content="Top Rated Movies"
                        Height="50"
                        Foreground="White"
                        FontSize="14"
                        Style="{StaticResource MenuButtonTheme}"/>

                <RadioButton Content="Top Rated TV Shows"
                        Height="50"
                        Foreground="White"
                        FontSize="14"
                        Style="{StaticResource MenuButtonTheme}"/>


            </StackPanel>

            <TextBox x:Name="SearchBar" 
                     Width="250" Height="40" 
                     VerticalContentAlignment="Center" 
                     HorizontalAlignment="Left" 
                     Margin="5" 
                     Grid.Column="1" 
                     Style="{StaticResource ModernTextbox}"/>

            <ContentControl x:Name="ContentBox" Grid.Row="1" Grid.Column="1" Margin="10">
                <ListBox ItemsSource="{Binding MoviePosters}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                          
                            <WrapPanel Orientation="Horizontal" Width="710" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                       
                            <Image Source="{Binding PosterPath}" Width="230" Height="345" Margin="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ContentControl>




            <TextBox x:Name="wyszukiwarka" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Center" Width="200" Height="39"/>



        </Grid>


    </Border>
</Window>